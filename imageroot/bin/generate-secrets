set -e

if ! [ -f secrets.env ]; then
    # Generate the API_PATH variable value
    if [[ -n ${API_PATH} ]] ; then
        # Import existing API_PATH from environment file, then erase it.
        # NOTE: the configs/_api.yml file contents were created by
        # create-module and will never reference the environment variable.
        api_path="${API_PATH:?}"
        python3 -c 'import agent ; agent.unset_env("API_PATH")'
        log_message="API_PATH imported and stored in secrets.env"
    else
        # Generate a new API_PATH key
        api_path="$(uuidgen)"
        log_message="API_PATH generated and stored in secrets.env"
    fi
    (umask 0077 ; printf "API_PATH=%s\n" "${api_path}" > secrets.env)
    echo "${log_message}"
fi

if ! [ -e selfsigned.crt ] || ! [ -e selfsigned.key ]; then
    # Generate a self-signed certificate for a random FQDN
    fqdn="host-$(printf %05d ${RANDOM}).ns8.test"
    openssl req -x509 \
        -days 3650 \
        -newkey rsa:4096 \
        -sha256 \
        -nodes \
        -keyout selfsigned.key \
        -out selfsigned.crt \
        -subj "/CN=${fqdn}" \
        -addext "subjectAltName=DNS:localhost,DNS:${fqdn}" \
    ; # end of openssl options
    echo "Self-signed certificate generated and stored in selfsigned.crt"
fi
